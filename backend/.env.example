# =============================================================================
# Emomo Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Local environment variables override configs/config.yaml. When
# CONFIG_CENTER_ENABLED=true, the remote config center overrides both at API
# startup, except for CONFIG_CENTER_* bootstrap values.

# =============================================================================
# VLM Configuration (Vision Language Model)
# =============================================================================
# Used for VLM/OCR auxiliary analysis and query expansion.
# Default vector retrieval uses Qwen3-VL image embeddings directly.
# Recommended for OpenRouter: bytedance-seed/seed-1.6-flash or qwen/qwen-2.5-vl-7b-instruct:free
VLM_PROVIDER=openai
VLM_MODEL=your-vlm-model-name
OPENAI_API_KEY=your-openai-or-openrouter-api-key
OPENAI_API_KEY_SECRET=OPENAI_API_KEY
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# To avoid external VLM calls for ingest text-presence labels:
# VLM_PROVIDER=local_text_presence
# VLM_MODEL=local-text-presence-tesseract
# LOCAL_ANALYZER_COMMAND=tesseract
# LOCAL_ANALYZER_LANG=chi_sim+eng
# LOCAL_ANALYZER_PSM=6

# =============================================================================
# Embedding Configuration
# =============================================================================
# These are referenced by api_key_env in configs/config.yaml

# SiliconFlow Qwen3-VL Embeddings (default in config.yaml)
SILICONFLOW_API_KEY=your-siliconflow-api-key
SILICONFLOW_API_KEY_SECRET=SILICONFLOW_API_KEY
# Optional override; the backend defaults to https://api.siliconflow.cn/v1
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# =============================================================================
# Search Configuration
# =============================================================================
# Query Expansion uses LLM to enrich short queries for better search results
QUERY_EXPANSION_ENABLED=true
QUERY_EXPANSION_MODEL=your-vlm-model-name
# Optional: Use a different LLM provider for query expansion
# If not set, defaults to VLM's OPENAI_API_KEY and OPENAI_BASE_URL
# QUERY_EXPANSION_API_KEY=your-api-key
# QUERY_EXPANSION_BASE_URL=https://api.example.com/v1
# For config-center publishing, use a Cloudflare Secrets Store Worker binding
# instead of publishing raw API keys into Workers KV. If query expansion uses
# the same provider key as VLM, OPENAI_API_KEY_SECRET is enough.
# QUERY_EXPANSION_API_KEY_SECRET=OPENAI_API_KEY

# =============================================================================
# Runtime Config Center (Optional)
# =============================================================================
# Use a Cloudflare Worker/KV/Secrets Store config center to publish complete
# backend config without editing Hugging Face Space variables.
# CONFIG_CENTER_ENABLED=false
# CONFIG_CENTER_REQUIRED=true
# CONFIG_CENTER_URL=https://your-config-worker.example.workers.dev/v1/config/emomo/production/emomo-api
# CONFIG_CENTER_TOKEN=read-token-used-by-backend
# CONFIG_CENTER_POLL_INTERVAL=60s
# CONFIG_CENTER_TIMEOUT=5s
# Used only by ./scripts/publish-config-center.sh, never by the running API.
# CONFIG_CENTER_ADMIN_TOKEN=admin-token-used-to-publish

# =============================================================================
# Storage Configuration (Cloudflare R2, AWS S3, MinIO, etc.)
# =============================================================================
# STORAGE_TYPE, STORAGE_REGION, and STORAGE_USE_SSL default in configs/config.yaml.
STORAGE_ENDPOINT=your-account-id.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_ACCESS_KEY_SECRET=STORAGE_ACCESS_KEY
STORAGE_SECRET_KEY=your-secret-key
STORAGE_SECRET_KEY_SECRET=STORAGE_SECRET_KEY
STORAGE_BUCKET=emomo
STORAGE_PUBLIC_URL=https://your-public-access-url.dev

# =============================================================================
# Qdrant Configuration (Vector Database)
# =============================================================================
QDRANT_HOST=your-qdrant-host
QDRANT_PORT=6334
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_API_KEY_SECRET=QDRANT_API_KEY
QDRANT_USE_TLS=true

# =============================================================================
# Database Configuration
# =============================================================================
# Current deployment path uses DATABASE_URL. Individual host/user/password
# fields are ignored by the backend whenever DATABASE_URL is set.
DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_URL_SECRET=DATABASE_URL
DATABASE_AUTO_MIGRATE=true

# =============================================================================
# Local Static Image Source
# =============================================================================
# Default directory used by `./scripts/import-data.sh` when no --path is passed.
LOCAL_MEMES_DIR=./data/memes
LOCALDIR_SOURCE_ID=localdir
# Optional JSONL metadata files for staged local exports.
# LOCALDIR_MANIFEST_PATH=./data/memes/stage2_results.jsonl
# LOCALDIR_QUEUE_PATH=./data/memes/stage1_queue.jsonl

# =============================================================================
# Server Configuration (Optional)
# =============================================================================
# PORT=8080
# Public API guardrails for web/mobile clients. Do not replace these with
# client-shipped private bearer tokens.
# PUBLIC_API_ENABLED=true
# PUBLIC_API_RATE_LIMIT_ENABLED=true
# PUBLIC_API_REQUESTS_PER_MINUTE=60
# PUBLIC_API_BURST=20
# PUBLIC_API_BODY_LIMIT_BYTES=16384
# PUBLIC_API_SEARCH_TOP_K_MAX=100
# PUBLIC_API_SEARCH_QUERY_MAX_RUNES=160
# PUBLIC_API_LIST_LIMIT_MAX=60

# =============================================================================
# Logging (Optional)
# =============================================================================
# API logs to stdout by default. Set LOKI_ENABLED=true to also push logs
# directly to Loki from the API process.
# API file logging is opt-in via LOG_FILE; stdout remains enabled unless
# LOG_FILE_ONLY=true.
# `./scripts/import-data.sh` writes JSON logs to both stdout and a rotating
# file. Defaults below; uncomment to override.
# APP_ENV=production                              # falls back to ENVIRONMENT
# LOG_LEVEL=info                                    # debug, info, warn, error
# LOG_FORMAT=json                                  # json, text
# LOG_DIR=./logs                                    # relative to backend/
# LOG_FILE=./logs/ingest-custom.log                 # full path (overrides LOG_DIR)
# LOG_FILE_ONLY=false
# LOG_MAX_SIZE=100
# LOG_MAX_BACKUPS=7
# LOG_MAX_AGE=30
# LOG_COMPRESS=true

# =============================================================================
# Loki Direct Push Configuration (Monitoring)
# =============================================================================
# LOKI_ENABLED=false
# LOKI_PROJECT=emomo
# LOKI_BATCH_SIZE=100
# LOKI_QUEUE_SIZE=5000
# LOKI_FLUSH_INTERVAL=2s
# LOKI_TIMEOUT=3s

# Grafana Cloud Loki endpoint (get from Grafana Cloud portal)
# Format: https://logs-prod-xxx.grafana.net/loki/api/v1/push
LOKI_URL=https://logs-prod-us-central1.grafana.net/loki/api/v1/push

# Grafana Cloud credentials
# Username: Your Grafana Cloud instance ID (numeric)
# Password: Your Grafana Cloud API key with logs:write scope
LOKI_USERNAME=123456
LOKI_PASSWORD=glc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LOKI_PASSWORD_SECRET=LOKI_PASSWORD

# Cluster/Environment identification
CLUSTER_NAME=production
ENVIRONMENT=production
