server:
  port: 8080
  mode: release
  public_api:
    enabled: true
    rate_limit_enabled: true
    requests_per_minute: 60
    burst: 20
    body_limit_bytes: 16384
    search_top_k_max: 100
    search_query_max_runes: 160
    list_limit_max: 60

database:
  driver: postgres  # 使用 PostgreSQL 数据库
  auto_migrate: true
  # 方式1: 使用连接字符串 URL（推荐，支持 Transaction Pooler）
  # 适用于 Supabase Transaction Pooler (端口 6543) 或 Session Pooler (端口 5432)
  # url: postgresql://postgres.juyjvbdplgwsravreplc:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
  # 方式2: 使用单独的字段配置
  # host: aws-1-ap-south-1.pooler.supabase.com
  # port: 6543  # Transaction Pooler 使用 6543，Session Pooler 使用 5432
  # user: postgres.juyjvbdplgwsravreplc
  # password: [YOUR-PASSWORD]  # 或通过环境变量 DATABASE_PASSWORD 设置
  # dbname: postgres
  # sslmode: require
  # SQLite 配置（如果使用 SQLite，取消下面的注释）
  # path: ./data/memes.db

# Qdrant Cloud 配置
# 生产环境启用配置中心后，api_key 由 Cloudflare Secrets Store 下发；
# 只有 CONFIG_CENTER_ENABLED=false 的 legacy 部署才在本地/HF 配置密钥。
qdrant:
  host: your-cluster.qdrant.io  # Qdrant Cloud 集群地址
  port: 6334                     # Qdrant Cloud gRPC 端口
  collection: emomo
  api_key: ""                     # legacy only when config center is disabled
  use_tls: true                  # Qdrant Cloud 需要 TLS

# S3 兼容存储配置（Cloudflare R2）
# 生产环境启用配置中心后，access_key/secret_key 由 Cloudflare Secrets Store 下发。
storage:
  type: r2                                          # 存储类型: r2, s3, s3compatible
  endpoint: your-account-id.r2.cloudflarestorage.com  # R2 S3 API endpoint
  access_key: ""                                    # legacy only when config center is disabled
  secret_key: ""                                    # legacy only when config center is disabled
  use_ssl: true                                     # R2 使用 HTTPS
  bucket: memes                                     # Bucket 名称
  region: auto                                      # R2 使用 "auto"
  public_url: https://pub-xxx.r2.dev                # R2.dev 公开访问 URL（image embedding 需要公网可访问）

# 如果使用 AWS S3，配置示例：
# storage:
#   type: s3
#   endpoint: s3.amazonaws.com
#   access_key: legacy-only-when-config-center-disabled
#   secret_key: legacy-only-when-config-center-disabled
#   use_ssl: true
#   bucket: your-bucket-name
#   region: us-east-1
#   public_url: https://your-bucket-name.s3.amazonaws.com

vlm:
  # Use local_text_presence only in environments that have the configured
  # local OCR command installed. Cloud defaults stay OpenAI-compatible.
  provider: openai
  model: qwen/qwen-2.5-vl-7b-instruct:free
  # api_key: 通过环境变量 OPENAI_API_KEY 设置
  base_url: https://openrouter.ai/api/v1
  local_analyzer_command: tesseract
  local_analyzer_lang: chi_sim+eng
  local_analyzer_psm: "6"

embeddings:
  - name: qwen3vl_image
    provider: siliconflow
    model: Qwen/Qwen3-VL-Embedding-8B
    api_key_env: SILICONFLOW_API_KEY
    base_url_env: SILICONFLOW_BASE_URL
    document_mode: image
    dimensions: 1024
    collection: meme_image_qwen3vl_1024
    is_default: true

  - name: qwen3vl_caption
    provider: siliconflow
    model: Qwen/Qwen3-VL-Embedding-8B
    api_key_env: SILICONFLOW_API_KEY
    base_url_env: SILICONFLOW_BASE_URL
    document_mode: text
    dimensions: 1024
    collection: meme_caption_qwen3vl_1024

ingest:
  workers: 5
  batch_size: 10
  retry_count: 3

search:
  score_threshold: 0.0
  default_profile: qwen3vl
  profiles:
    - name: qwen3vl
      image_embedding: qwen3vl_image
      keyword_embedding: qwen3vl_caption
      is_default: true
  retrieval:
    image_top_k: 100
    caption_top_k: 100
    final_top_k: 100
    weights:
      image: 0.70
      caption: 0.00
      keyword: 0.30
  query_expansion:
    enabled: true
    model: qwen/qwen-2.5-vl-7b-instruct:free
  agentic:
    enabled: false
    planner_model: ""
    reranker_model: ""
    planner_timeout: 8s
    reranker_timeout: 10s
    rerank_top_k: 40
    fallback_on_error: true

config_center:
  # Optional: set CONFIG_CENTER_* env vars in Hugging Face to load complete
  # backend config from the Worker. Query expansion can also hot-update.
  enabled: false
  required: false
  url: ""
  token: ""
  poll_interval: 60s
  timeout: 5s

logging:
  level: info
  format: json
  service_name: emomo-api
  environment: production
  log_file: ""
  log_file_only: false
  max_size: 100
  max_backups: 7
  max_age: 30
  compress: true
  loki_enabled: false
  loki_url: ""
  loki_username: ""
  loki_password: ""
  loki_project: emomo
  cluster_name: production
  loki_batch_size: 100
  loki_queue_size: 5000
  loki_flush_interval: 2s
  loki_timeout: 3s

sources:
  localdir:
    enabled: true
    root_path: ./data/memes
    source_id: localdir
    manifest_path: ""
    queue_path: ""
