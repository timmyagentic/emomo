# Hugging Face Spaces 环境变量配置模板
# 使用方法：复制以下内容，在 Hugging Face Spaces 的 Settings → Secrets and variables → Variables 中逐个添加
# 注意：生产环境启用配置中心后，API key、数据库 URL、对象存储密钥、
# Qdrant API key、Loki 密码等高敏感值不再放到 Hugging Face；
# 只保留 CONFIG_CENTER_TOKEN 作为读取配置中心的一次性 bootstrap secret。

# ============================================
# Qdrant 配置（配置中心开启时由 Cloudflare Worker 下发）
# ============================================
# QDRANT_HOST=your-cluster.qdrant.io
# QDRANT_PORT=6334
# QDRANT_USE_TLS=true
# QDRANT_API_KEY=legacy-only-when-config-center-disabled

# ============================================
# 存储配置 - Cloudflare R2（配置中心开启时由 Cloudflare Worker 下发）
# ============================================
# STORAGE_TYPE=r2
# STORAGE_ENDPOINT=https://<YOUR_ACCOUNT_ID>.r2.cloudflarestorage.com
# STORAGE_USE_SSL=true
# STORAGE_BUCKET=<YOUR_BUCKET_NAME>
# STORAGE_PUBLIC_URL=https://pub-<random-id>.r2.dev
# STORAGE_ACCESS_KEY=legacy-only-when-config-center-disabled
# STORAGE_SECRET_KEY=legacy-only-when-config-center-disabled

# ============================================
# 存储配置 - Backblaze B2（Variables）
# ============================================
# STORAGE_TYPE=s3
# STORAGE_ENDPOINT=s3.us-west-000.backblazeb2.com
# STORAGE_USE_SSL=true
# STORAGE_BUCKET=your-bucket-name
# STORAGE_ACCESS_KEY=legacy-only-when-config-center-disabled
# STORAGE_SECRET_KEY=legacy-only-when-config-center-disabled

# ============================================
# API Keys（配置中心开启时由 Cloudflare Secrets Store 下发）
# ============================================
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# VLM_MODEL=qwen/qwen-2.5-vl-7b-instruct:free
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_API_KEY=legacy-only-when-config-center-disabled
# SILICONFLOW_API_KEY=legacy-only-when-config-center-disabled

# ============================================
# 配置中心（Variables / Secrets）
# ============================================
# Variables:
# CONFIG_CENTER_ENABLED=true
# CONFIG_CENTER_REQUIRED=true
# CONFIG_CENTER_URL=https://your-worker.example.workers.dev/v1/config/emomo/production/emomo-api
# CONFIG_CENTER_POLL_INTERVAL=60s
# CONFIG_CENTER_TIMEOUT=5s
# Secrets:
# CONFIG_CENTER_TOKEN=your-read-token
# Provider/database/storage/logging API keys should live in Cloudflare Secrets
# Store and be referenced by local publish payloads as *_SECRET binding names,
# not copied into Hugging Face.

# ============================================
# 应用配置（Variables）
# ============================================
# PORT=7860  # Hugging Face Spaces 默认使用 7860，无需修改
# LOG_LEVEL=info  # 可选，默认 info
