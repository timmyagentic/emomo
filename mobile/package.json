{
  "name": "emomo-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "assets:generate": "node scripts/generate-brand-assets.js",
    "gen": "buf generate --template buf.gen.yaml",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "jest"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.35",
    "expo-clipboard": "~8.0.8",
    "expo-file-system": "~19.0.23",
    "expo-media-library": "~18.2.1",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.7",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "jest-expo": "~54.0.17",
    "pngjs": "^7.0.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/gen/"
    ]
  }
}
