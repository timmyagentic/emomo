{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.12.0",
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://tingjunn-emomo.hf.space/api/v1"
      }
    },
    "ios-simulator": {
      "extends": "base",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appName": "emomo - Meme Search",
        "ascAppId": "6776160506",
        "bundleIdentifier": "com.timmy.emomo",
        "language": "zh-Hans",
        "metadataPath": "./store.config.json",
        "sku": "com.timmy.emomo"
      }
    }
  }
}
