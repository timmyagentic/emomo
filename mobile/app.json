{
  "expo": {
    "name": "emomo",
    "slug": "emomo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "emomo",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.timmy.emomo",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.timmy.emomo",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow emomo to access photos only when saving memes.",
          "savePhotosPermission": "Allow emomo to save memes to your photo library.",
          "granularPermissions": [
            "photo"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9550b08d-da2c-4075-8bbc-e4579773fc30"
      }
    },
    "owner": "timmy3956"
  }
}
