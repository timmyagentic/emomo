{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "emomo-api-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-07",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    { "pattern": "api.emomo.net", "custom_domain": true }
  ],
  "vars": {
    "UPSTREAM_ORIGIN": "https://tingjunn-emomo.hf.space",
    "CORS_ALLOWED_ORIGINS": "https://emomo.net,https://www.emomo.net",
    "CACHE_TTL_SECONDS": "30",
    "MAX_REQUEST_BODY_BYTES": "65536",
    "MAX_LIST_WINDOW": "120",
    "MAX_SEARCH_TOP_K": "100"
  },
  "ratelimits": [
    {
      "name": "EMOMO_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 120,
        "period": 60
      }
    }
  ],
  "secrets": {
    "required": ["HF_TOKEN"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
